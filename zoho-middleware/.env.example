# ─────────────────────────────────────────────────────────────
# Steins & Vines — Middleware Environment Variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3001                                  # Express listen port (Railway sets this automatically)
NODE_ENV=development                       # "production" enables compact logging

# ── Zoho OAuth2 ────────────────────────────────────────────
# Required. Register your app at your region's API console:
#   US: https://api-console.zoho.com
#   CA: https://api-console.zohocloud.ca
#   EU: https://api-console.zoho.eu
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REDIRECT_URI=http://localhost:3001/auth/zoho/callback
ZOHO_ORG_ID=your_organization_id_here
ZOHO_DOMAIN=.ca                            # .com (US), .ca (Canada), .eu (EU), .in (India), .com.au (AU), .jp (Japan)

# ── Zoho Bookings ──────────────────────────────────────────
# Required for reservation/appointment endpoints (from Bookings admin UI).
ZOHO_BOOKINGS_SERVICE_ID=your_service_id_here
ZOHO_BOOKINGS_STAFF_ID=your_staff_id_here

# ── Zoho Custom Fields ────────────────────────────────────
# API names of custom fields on Zoho Sales Orders. Used by checkout and POS
# to attach metadata (appointment ID, timeslot, deposit, etc.) to orders.
# Optional — features degrade gracefully if unset.
ZOHO_CF_APPOINTMENT_ID=cf_appointment_id
ZOHO_CF_TIMESLOT=cf_appointment_timeslot
ZOHO_CF_STATUS=cf_reservation_status
ZOHO_CF_DEPOSIT=cf_deposit_amount
ZOHO_CF_BALANCE=cf_balance_due
ZOHO_CF_TRANSACTION_ID=cf_payment_transaction_id

# ── Zoho Tax IDs ──────────────────────────────────────────
# Override default Zoho tax rule and tax ID values. Defaults are baked into
# routes/taxes.js — only set these if your Zoho org uses different IDs.
# ZOHO_TAX_STANDARD_RULE=
# ZOHO_TAX_STANDARD_ID=
# ZOHO_TAX_ZERO_RULE=
# ZOHO_TAX_ZERO_ID=
# ZOHO_TAX_SERVICES_RULE=
# ZOHO_TAX_SERVICES_ID=
# ZOHO_TAX_LIQUOR_RULE=
# ZOHO_TAX_LIQUOR_ID=

# ── Zoho Webhook ──────────────────────────────────────────
ZOHO_WEBHOOK_SECRET=your-secret-token

# ── Global Payments (GP-API) ──────────────────────────────
# Required for card-not-present payments (online checkout).
# Get from developer.globalpayments.com
GP_APP_ID=your_app_id_here
GP_APP_KEY=your_app_key_here
GP_MERCHANT_ID=MER_your_merchant_id_here
GP_ENVIRONMENT=test                        # "test" (sandbox) or "production"
GP_DEPOSIT_AMOUNT=50.00                    # Default deposit amount for reservations ($)

# ── GP Terminal (in-store kiosk) ──────────────────────────
# Optional. Enable only if using a physical payment terminal.
GP_TERMINAL_ENABLED=false                  # "true" to enable terminal support

# ── API Security ──────────────────────────────────────────
# Required. Protects all mutating /api/* endpoints (POST, PUT, DELETE).
# The frontend admin panel and kiosk send this as the X-Api-Key header.
# If unset, all mutating endpoints return 503.
API_SECRET_KEY=

# ── MW API Key (POS/recent orders) ────────────────────────
# Used by the /api/orders/recent endpoint for admin access.
# MW_API_KEY=

# ── Kiosk ─────────────────────────────────────────────────
# KIOSK_CONTACT_ID=                        # Zoho contact ID for walk-in kiosk sales
# KIOSK_TAX_RATE=0.05                      # Tax rate applied to kiosk sales (default 5%)

# ── reCAPTCHA ─────────────────────────────────────────────
# Required for public checkout endpoint spam protection.
RECAPTCHA_SECRET_KEY=                      # Google reCAPTCHA v3 secret key

# ── Google Apps Script ────────────────────────────────────
# Optional. Used by checkout to log orders to a Google Sheet.
# APPS_SCRIPT_URL=                         # Deployed Apps Script web app URL
# APPS_SCRIPT_SERVER_TOKEN=                # Auth token for the Apps Script endpoint

# ── Redis ─────────────────────────────────────────────────
# Required for caching, rate limiting, and idempotency keys.
# Falls back gracefully if unavailable (in-memory rate limiting, no caching).
REDIS_URL=redis://localhost:6379

# ── Email (SMTP) ─────────────────────────────────────────
# Required for order notifications, reservation confirmations, and void alerts.
SMTP_HOST=smtp.gmail.com                   # SMTP server hostname
SMTP_PORT=587                              # SMTP port (587 for TLS)
SMTP_USER=                                 # SMTP username (e.g. Gmail address)
SMTP_PASS=                                 # SMTP password (use Gmail App Password, not account password)
CONTACT_TO=hello@steinsandvines.ca         # Recipient for contact form + order/void notifications

# ── Sentry ────────────────────────────────────────────────
# Optional. Error tracking and performance monitoring.
SENTRY_DSN=your-sentry-node-dsn

# ── Logging ───────────────────────────────────────────────
# LOG_LEVEL=debug                          # Set to "debug" for verbose logging

# ── Makers Fee ────────────────────────────────────────────
# MAKERS_FEE_ITEM_ID=                      # Zoho item ID for the maker's fee line item

# ── Frontend Origin (CORS) ────────────────────────────────
FRONTEND_URL=http://localhost:3000
